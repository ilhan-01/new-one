body{
    margin:0;
    min-height:100vh;
    font-family:Arial, sans-serif;

    background:linear-gradient(
        to bottom,
        #d8c4f0 0%,
        #e8ddf8 40%,
        #b8e6b8 75%,
        #7ccf7c 100%
    );

    display:flex;
    justify-content:center;
    align-items:center;
    overflow:hidden;
    position:relative;
}

body::after{
    content:"";
    position:absolute;
    bottom:0;
    left:0;
    width:100%;
    height:120px;

    background:repeating-linear-gradient(
        90deg,
        #4caf50 0px,
        #4caf50 8px,
        #43a047 8px,
        #43a047 16px
    );

    z-index:-1;
}

.garden-left,
.garden-right{
    position:fixed;
    top:0;
    width:120px;
    height:100vh;
    font-size:40px;

    display:flex;
    flex-direction:column;
    justify-content:space-around;

    z-index:-1;
}

.garden-left{
    left:10px;
}

.garden-right{
    right:10px;
}

.card{
    text-align:center;
    background:white;
    padding:40px;
    border-radius:25px;
    box-shadow:0 10px 30px rgba(0,0,0,0.15);
}

.card h1{
    color:#7d4ba0;
}

.buttons{
    margin-top:30px;
}

button{
    border:none;
    padding:15px 35px;
    margin:10px;
    border-radius:15px;
    cursor:pointer;
    font-size:18px;
    transition:0.3s;
}

button:hover{
    transform:scale(1.05);
}

#yesBtn{
    background:#b57edc;
    color:white;
}

#noBtn{
    background:#dddddd;
}

.hidden{
    display:none;
}

#surprise{
    text-align:center;
    max-width:900px;
    padding:40px;

    background:rgba(255,255,255,0.88);

    border-radius:30px;

    box-shadow:0 0 30px rgba(181,126,220,.4);
}

.arch{
    font-size:40px;
    margin-bottom:20px;
}

.name{
    font-size:4rem;
    color:#8a5cbf;
    margin-bottom:10px;
}

.subtitle{
    color:#6c4f84;
}

.flowers{
    display:flex;
    justify-content:center;
    gap:40px;
    margin-top:40px;
    flex-wrap:wrap;
}

.flowers div{
    font-size:5rem;
    display:flex;
    flex-direction:column;
    align-items:center;
    animation:float 3s ease-in-out infinite;
}

.flowers span{
    font-size:16px;
    margin-top:10px;
    color:#555;
}

.quote{
    margin-top:40px;
    font-size:1.6rem;
    color:#5c476e;
    font-style:italic;
    line-height:1.6;
}

.message{
    margin-top:30px;
    font-size:1.2rem;
    line-height:1.8;
    color:#444;
}

.heart{
    position:absolute;
    bottom:-50px;
    font-size:30px;
    animation:rise linear forwards;
}

@keyframes rise{
    from{
        transform:translateY(0);
        opacity:1;
    }

    to{
        transform:translateY(-110vh);
        opacity:0;
    }
}

@keyframes float{
    0%,100%{
        transform:translateY(0);
    }

    50%{
        transform:translateY(-15px);
    }
}
